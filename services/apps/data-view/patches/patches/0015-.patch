+		updateStart = lastSyncTimeMs - int64(bufferMinutes*60*1000)
+		if updateStart < 0 {
+			updateStart = 0
+		}
+		log.WithContext(ctx).Infof("incremental sync: lastSyncTimeMs=%d, adjusted=%d (minus %d minutes)",
+			lastSyncTimeMs, updateStart, bufferMinutes)
+	}

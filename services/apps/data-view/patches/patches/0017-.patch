 domain/form_view/v1/internal.go | 20 ++++++++++++++------
 1 file changed, 14 insertions(+), 6 deletions(-)

diff --git a/domain/form_view/v1/internal.go b/domain/form_view/v1/internal.go
index 3c687b16..4e5cb3bc 100644
--- a/domain/form_view/v1/internal.go
+++ b/domain/form_view/v1/internal.go
@@ -215,13 +215,21 @@ func (f *formViewUseCase) Sync(ctx context.Context) {
 		viewMap[v.Id] = v
 		needSyncIDs = append(needSyncIDs, v.Id)
 	}
-	
-	viewInfos := make([]*mdl_data_model.GetDataViewResp, 0)
+	viewInfos := make([]*mdl_data_model.GetDataViewResp, 0, len(needSyncIDs))
 	if len(needSyncIDs) > 0 {
-		viewInfos, err = f.DrivenMdlDataModel.GetDataView(ctx, needSyncIDs)
-		if err != nil {
-			log.WithContext(ctx).Error("get data view detail from mdl-data-model fail", zap.Error(err))
-			return
+		const batchSize = 1000
+		for start := 0; start < len(needSyncIDs); start += batchSize {
+			end := start + batchSize
+			if end > len(needSyncIDs) {
+				end = len(needSyncIDs)
+			}
+			batchIDs := needSyncIDs[start:end]
+			batchInfos, err := f.DrivenMdlDataModel.GetDataView(ctx, batchIDs)
+			if err != nil {
+				log.WithContext(ctx).Error("get data view detail from mdl-data-model fail", zap.Error(err), zap.Int("batchSize", len(batchIDs)))
+				return
+			}
+			viewInfos = append(viewInfos, batchInfos...)
 		}
 	}
 	if err = f.CompareFormView(ctx, viewMap, viewInfos, fullSync, formViews); err != nil {

+// prepareFormViewSync 构建 formViews 映射并预生成编码，不依赖全量视图详情，用于分批同步时降低内存。
+func (f *formViewUseCase) prepareFormViewSync(ctx context.Context, viewMap map[string]*mdl_data_model.DataViewInfo, needSyncIDs []string, formViews []*model.FormView) (
+	formViewsMap map[string]*FormViewFlag,
+	formViewInfosMap map[string]*FormViewFlag,
+	codeList *configuration_center.CodeList,
+	err error,
+) {
+	formViewsMap = make(map[string]*FormViewFlag)
+	formViewInfosMap = make(map[string]*FormViewFlag)
+	for _, formView := range formViews {
+		if formView.MdlID != "" {
+			formViewsMap[formView.MdlID] = &FormViewFlag{FormView: formView, flag: 1}
+		} else {
+			tmp := fmt.Sprintf("%s %s", formView.DatasourceID, formView.TechnicalName)
+			formViewInfosMap[tmp] = &FormViewFlag{FormView: formView, flag: 1}
+		}
+	}
+
+	// 仅根据列表 viewMap + formViewsMap 计算需要新编码的数量，不依赖全量 GetDataViewResp
+	var uniformCatalogCodeCount int
+	for _, id := range needSyncIDs {
+		info := viewMap[id]
+		if info == nil {
+			continue
+		}
+		tmp := fmt.Sprintf("%s %s", info.DataSourceId, info.TechnicalName)
+		fv := formViewsMap[id]
+		if fv == nil {
+			fv = formViewInfosMap[tmp]
+		}
+		if fv == nil || fv.FormView == nil {
+			uniformCatalogCodeCount++
+			continue
+		}
+		if fv.FormView.UniformCatalogCode == "" {
+			uniformCatalogCodeCount++
+		}
+	}
+
+	codeList = &configuration_center.CodeList{Entries: make([]string, 0)}
+	if uniformCatalogCodeCount > 0 {
+		var genErr error
+		codeList, genErr = f.configurationCenterDrivenNG.Generate(ctx, CodeGenerationRuleUUIDDataView, uniformCatalogCodeCount)
+		if agerrors.Code(genErr).GetErrorCode() == "ConfigurationCenter.CodeGenerationRule.NotFound" {
+			log.WithContext(ctx).Warn("generate code for data view fail", zap.Error(genErr), zap.Stringer("rule", CodeGenerationRuleUUIDDataView), zap.Int("count", uniformCatalogCodeCount))
+			codeList = &configuration_center.CodeList{Entries: make([]string, uniformCatalogCodeCount)}
+		} else if genErr != nil {
+			log.WithContext(ctx).Error("generate code for data view fail", zap.Error(genErr), zap.Stringer("rule", CodeGenerationRuleUUIDDataView), zap.Int("count", uniformCatalogCodeCount))
+			return nil, nil, nil, genErr
+		}
+	}
+	return formViewsMap, formViewInfosMap, codeList, nil
+}
+
+// compareFormViewBatch 对单批视图详情做新增/更新，更新 formViewsMap 的 flag，便于后续全量删除判定。
+func (f *formViewUseCase) compareFormViewBatch(ctx context.Context, tables []*mdl_data_model.GetDataViewResp, viewMap map[string]*mdl_data_model.DataViewInfo,
+	formViewsMap map[string]*FormViewFlag, formViewInfosMap map[string]*FormViewFlag, codeList *configuration_center.CodeList, codeListIndex *int) error {
+	for _, table := range tables {
+		tmp := fmt.Sprintf("%s %s", table.DataSourceId, table.TechnicalName)
+		var fvFlag *FormViewFlag
+		if formViewsMap[table.Id] != nil {
+			fvFlag = formViewsMap[table.Id]
+		} else if formViewInfosMap[tmp] != nil {
+			fvFlag = formViewInfosMap[tmp]
+		}
+
+		if fvFlag == nil || fvFlag.FormView == nil {
+			var code string
+			if codeList != nil && *codeListIndex < len(codeList.Entries) {
+				code = codeList.Entries[*codeListIndex]
+			}
+			if err := f.newFormView(ctx, code, viewMap, table); err != nil {
+				return err
+			}
+			*codeListIndex++
+		} else {
+			newUniformCatalogCode := fvFlag.FormView.UniformCatalogCode == ""
+			if newUniformCatalogCode {
+				if codeList != nil && *codeListIndex < len(codeList.Entries) {
+					fvFlag.FormView.UniformCatalogCode = codeList.Entries[*codeListIndex]
+				}
+				*codeListIndex++
+			}
+			if err := f.updateFormView(ctx, fvFlag.FormView, table, newUniformCatalogCode); err != nil {
+				return err
+			}
+			fvFlag.flag = 2
+		}
+	}
+	return nil
+}
+
